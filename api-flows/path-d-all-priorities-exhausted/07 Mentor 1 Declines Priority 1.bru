meta {
  name: Mentor 1 Declines Priority 1
  type: http
  seq: 7
}

patch {
  url: {{baseUrl}}/api/platform/v1/mentors/applications/:applicationId/decline
  body: json
  auth: apikey
}

params:path {
  applicationId: {{pD_appId_p1}}
}

auth:apikey {
  key: X-API-KEY
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "reason": "Not available this cycle."
  }
}

tests {
  test("Response Status is OK (200)", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Priority 1 application is MENTOR_DECLINED", function() {
    const body = res.getBody();
    expect(body.status).to.equal("MENTOR_DECLINED");
  });
}
