meta {
  name: Mentor 3 Declines Priority 3
  type: http
  seq: 9
}

patch {
  url: {{baseUrl}}/api/platform/v1/mentors/applications/:applicationId/decline
  body: json
  auth: apikey
}

params:path {
  applicationId: {{pD_appId_p3}}
}

auth:apikey {
  key: X-API-KEY
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "reason": "Taking a break from mentoring."
  }
}

tests {
  test("Response Status is OK (200)", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Priority 3 application is MENTOR_DECLINED", function() {
    const body = res.getBody();
    expect(body.status).to.equal("MENTOR_DECLINED");
  });
}
